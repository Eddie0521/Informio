{
  "name": "informio",
  "version": "0.1.13",
  "description": "A minimal Markdown editor with contextual MCP Agent assistance.",
  "license": "AGPL-3.0-only",
  "homepage": "https://github.com/Eddie0521/Informio",
  "repository": {
    "type": "git",
    "url": "https://github.com/Eddie0521/Informio.git"
  },
  "bugs": {
    "url": "https://github.com/Eddie0521/Informio/issues"
  },
  "main": "out/main/index.js",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "rollup": "npm:@rollup/wasm-node@4.60.3"
    }
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "test": "vitest run --exclude e2e",
    "test:cov": "vitest run --exclude e2e --coverage",
    "test:e2e": "electron-vite build && playwright test",
    "typecheck": "tsc --noEmit",
    "preview": "electron-vite preview",
    "dist:mac": "node scripts/run-electron-builder.cjs --mac dmg zip --config electron-builder.config.ts",
    "dist:mac:unsigned": "CSC_IDENTITY_AUTO_DISCOVERY=false node scripts/run-electron-builder.cjs --mac dmg zip -c.mac.identity=null -c.mac.notarize=false -c.mac.hardenedRuntime=false -c.dmg.sign=false --config electron-builder.config.ts",
    "release:mac:unsigned": "tsc --noEmit && electron-vite build && CSC_IDENTITY_AUTO_DISCOVERY=false node scripts/run-electron-builder.cjs --mac dmg zip -c.mac.identity=null -c.mac.notarize=false -c.mac.hardenedRuntime=false -c.dmg.sign=false --config electron-builder.config.ts",
    "dist:win": "node scripts/run-electron-builder.cjs --win nsis --config electron-builder.config.ts",
    "release:win": "tsc --noEmit && electron-vite build && node scripts/run-electron-builder.cjs --win nsis --config electron-builder.config.ts",
    "dist:desktop": "node scripts/run-electron-builder.cjs --mac dmg zip --win nsis --config electron-builder.config.ts",
    "release": "node scripts/run-electron-builder.cjs --mac dmg zip --win nsis --publish always --config electron-builder.config.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.144",
    "@anthropic-ai/sdk": "^0.96.0",
    "@embedpdf/react-pdf-viewer": "^2.14.3",
    "@opencode-ai/sdk": "^1.15.5",
    "@tanstack/react-virtual": "^3.14.2",
    "electron-log": "^5.4.4",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.6.2",
    "i18next": "^26.3.1",
    "isexe": "^2.0.0",
    "path-key": "^3.1.1",
    "react-i18next": "^17.0.8",
    "shebang-command": "^2.0.0",
    "shebang-regex": "^3.0.0",
    "which": "^2.0.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.16",
    "@tiptap/core": "3.23.4",
    "@tiptap/extension-code-block-lowlight": "^3.23.4",
    "@tiptap/extension-highlight": "3.23.4",
    "@tiptap/extension-image": "3.23.4",
    "@tiptap/extension-link": "3.23.4",
    "@tiptap/extension-placeholder": "^3.23.4",
    "@tiptap/extension-subscript": "3.23.4",
    "@tiptap/extension-superscript": "3.23.4",
    "@tiptap/extension-table": "3.23.4",
    "@tiptap/extension-table-cell": "3.23.4",
    "@tiptap/extension-table-header": "3.23.4",
    "@tiptap/extension-table-row": "3.23.4",
    "@tiptap/extension-task-item": "3.23.4",
    "@tiptap/extension-task-list": "3.23.4",
    "@tiptap/extension-underline": "3.23.4",
    "@tiptap/markdown": "^3.23.4",
    "@tiptap/pm": "3.23.4",
    "@tiptap/react": "^3.23.4",
    "@tiptap/starter-kit": "^3.23.4",
    "@types/node": "^24.9.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^4.1.8",
    "clsx": "^2.1.1",
    "electron": "^38.3.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.0",
    "jsdom": "^29.1.1",
    "katex": "^0.16.47",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.552.0",
    "mermaid": "^11.15.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vitest": "^4.1.8",
    "yaml": "^2.9.0"
  }
}
